<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:ui="clr-namespace:DeltaT.App.Ui"
                    xmlns:controls="clr-namespace:DeltaT.App.Controls"
                    mc:Ignorable="po">

    <!-- ================================================================
         DeltaT design language: "ember console" (docs/DESIGN.md).
         Gaming-console instrument dialect: warm soot
         surfaces with a faint ember glow, one signal color (ember orange),
         chamfered plates with corner brackets, hazard-stripe ribbons.
         Bahnschrift (DIN) for identity and bold condensed numerals,
         Cascadia Mono for live data, Segoe UI for sentences.
         Thermal semantics: steel (cool) -> amber (warm) -> orange -> red
         (limit). Green only ever means "verdict: healthy".
         One loud element per screen; the rest is soot.
         ================================================================ -->

    <!-- Surfaces -->
    <Color x:Key="Col.Bg">#0E0A07</Color>
    <Color x:Key="Col.Rail">#060403</Color>
    <Color x:Key="Col.Panel">#17100A</Color>
    <Color x:Key="Col.PanelHigh">#211711</Color>
    <Color x:Key="Col.InputBg">#080504</Color>
    <Color x:Key="Col.Stroke">#332418</Color>
    <Color x:Key="Col.StrokeSoft">#251A11</Color>

    <!-- Text -->
    <Color x:Key="Col.Text">#F2E8DC</Color>
    <Color x:Key="Col.TextDim">#AE9884</Color>
    <Color x:Key="Col.TextFaint">#6E5C4B</Color>

    <!-- Thermal semantics -->
    <Color x:Key="Col.Cool">#7FA2B8</Color>
    <Color x:Key="Col.Warm">#ECAF3A</Color>
    <Color x:Key="Col.HotWarn">#F4741F</Color>
    <Color x:Key="Col.Hot">#E93A2B</Color>
    <Color x:Key="Col.Good">#57C465</Color>

    <!-- Signal -->
    <Color x:Key="Col.Accent">#F26A1B</Color>
    <Color x:Key="Col.AccentBright">#FF9247</Color>
    <Color x:Key="Col.AccentDim">#38200E</Color>
    <Color x:Key="Col.AccentEdge">#7A4218</Color>
    <Color x:Key="Col.Bracket">#8CF26A1B</Color>

    <SolidColorBrush x:Key="Brush.Bg" Color="{StaticResource Col.Bg}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.Rail" Color="{StaticResource Col.Rail}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.Panel" Color="{StaticResource Col.Panel}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.PanelHigh" Color="{StaticResource Col.PanelHigh}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.InputBg" Color="{StaticResource Col.InputBg}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.Stroke" Color="{StaticResource Col.Stroke}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.StrokeSoft" Color="{StaticResource Col.StrokeSoft}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.Text" Color="{StaticResource Col.Text}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.TextDim" Color="{StaticResource Col.TextDim}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.TextFaint" Color="{StaticResource Col.TextFaint}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.Cool" Color="{StaticResource Col.Cool}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.Warm" Color="{StaticResource Col.Warm}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.HotWarn" Color="{StaticResource Col.HotWarn}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.Hot" Color="{StaticResource Col.Hot}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.Good" Color="{StaticResource Col.Good}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Col.Accent}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.AccentBright" Color="{StaticResource Col.AccentBright}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.AccentDim" Color="{StaticResource Col.AccentDim}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.AccentEdge" Color="{StaticResource Col.AccentEdge}" po:Freeze="True"/>
    <SolidColorBrush x:Key="Brush.Bracket" Color="{StaticResource Col.Bracket}" po:Freeze="True"/>

    <!-- Window base: soot with a low ember glow rising from the bottom right —
         the console mood without shipping a bitmap. Windows use this as
         Background and lay Brush.BgDots on top. -->
    <RadialGradientBrush x:Key="Brush.BgGlow" GradientOrigin="0.72,1.42" Center="0.72,1.42"
                         RadiusX="1.6" RadiusY="1.25" po:Freeze="True">
        <GradientStop Color="#241209" Offset="0"/>
        <GradientStop Color="#150D08" Offset="0.6"/>
        <GradientStop Color="#0E0A07" Offset="1"/>
    </RadialGradientBrush>

    <!-- 22px-pitch dot grid, warm-white at ~4%: graph paper, visible only if
         you look for it. Transparent tile — overlay it on Brush.BgGlow. -->
    <DrawingBrush x:Key="Brush.BgDots" TileMode="Tile" Viewport="0,0,22,22" ViewportUnits="Absolute"
                  po:Freeze="True">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#00000000">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,22,22"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#0BF2E8DC">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="10.5,10.5,1.2,1.2"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Hazard ribbon: the ///// stripe motif that ends every module header
         (and the dim variant for quieter chrome). -->
    <DrawingBrush x:Key="Brush.Hazard" TileMode="Tile" Viewport="0,0,8,7" ViewportUnits="Absolute"
                  po:Freeze="True">
        <DrawingBrush.Drawing>
            <GeometryDrawing Brush="#96F26A1B" Geometry="M 0,7 L 3.5,0 L 6,0 L 2.5,7 Z"/>
        </DrawingBrush.Drawing>
    </DrawingBrush>
    <DrawingBrush x:Key="Brush.HazardDim" TileMode="Tile" Viewport="0,0,8,7" ViewportUnits="Absolute"
                  po:Freeze="True">
        <DrawingBrush.Drawing>
            <GeometryDrawing Brush="#52322114" Geometry="M 0,7 L 3.5,0 L 6,0 L 2.5,7 Z"/>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Three voices: DIN for identity, bold condensed DIN for numerals,
         mono for live data, Segoe for sentences. -->
    <FontFamily x:Key="Font.Display">Bahnschrift, Segoe UI</FontFamily>
    <FontFamily x:Key="Font.DisplayCond">Bahnschrift Condensed, Bahnschrift, Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Mono">Cascadia Mono, Consolas</FontFamily>
    <FontFamily x:Key="Font.Ui">Segoe UI Variable Text, Segoe UI</FontFamily>

    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <ui:ZeroToVisibilityConverter x:Key="ZeroToVis"/>
    <ui:StringMatchToVisibilityConverter x:Key="StateToVis"/>
    <ui:InverseBooleanConverter x:Key="InvertBool"/>
    <ui:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    <ui:StringMatchToBoolConverter x:Key="StateToBool"/>
    <ui:FractionToBrushConverter x:Key="FracToBrush"/>

    <!-- ============================== text styles -->

    <Style x:Key="Text.Caption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Mono}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextFaint}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <Style x:Key="Text.Label" TargetType="TextBlock" BasedOn="{StaticResource Text.Caption}">
        <Setter Property="FontSize" Value="10.5"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextDim}"/>
    </Style>

    <!-- Tracked DIN caps in the signal color — section labels read like panel
         silkscreen. Pair with ui:Tracking.Text. -->
    <Style x:Key="Text.Overline" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Display}"/>
        <Setter Property="FontSize" Value="10.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Accent}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <Style x:Key="Text.OverlineFaint" TargetType="TextBlock" BasedOn="{StaticResource Text.Overline}">
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextFaint}"/>
    </Style>

    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="Text.Dim" TargetType="TextBlock" BasedOn="{StaticResource Text.Body}">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextDim}"/>
    </Style>

    <!-- Mono data readout (timestamps, deltas, table values). -->
    <Style x:Key="Text.Numeral" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Mono}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <!-- Bold condensed DIN for the big readings — the gauge voice. -->
    <Style x:Key="Text.Display" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.DisplayCond}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
    </Style>

    <Style x:Key="Text.H1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Display}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
    </Style>

    <Style x:Key="Text.H2" TargetType="TextBlock" BasedOn="{StaticResource Text.H1}">
        <Setter Property="FontSize" Value="15"/>
    </Style>

    <!-- ============================== panels -->

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Panel}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="16,14"/>
    </Style>

    <Style x:Key="Chip" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.PanelHigh}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="8,3"/>
    </Style>

    <!-- Kept for ad-hoc header rules (2px-high grid). -->
    <Style x:Key="IndexRule" TargetType="Grid">
        <Setter Property="Height" Value="2"/>
    </Style>

    <!-- ============================== brand mark -->

    <!-- The wordmark's delta carries the ember→red identity gradient — the one
         licensed non-data gradient besides the window glow. -->
    <LinearGradientBrush x:Key="Brush.BrandDelta" StartPoint="0.5,0" EndPoint="0.5,1" po:Freeze="True">
        <GradientStop Color="{StaticResource Col.AccentBright}" Offset="0"/>
        <GradientStop Color="{StaticResource Col.Accent}" Offset="0.55"/>
        <GradientStop Color="{StaticResource Col.Hot}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Brand.Mark: the machined ΔT — a chamfered outline delta with the identity
         gradient, the T nested into the empty space above its right slope so the
         pair reads as one ligature. Defined once; every window chrome uses this
         (wrap in a Viewbox to scale, e.g. the onboarding hero). -->
    <Style x:Key="Brand.Mark" TargetType="ContentControl">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <StackPanel Orientation="Horizontal">
                        <Path VerticalAlignment="Center" Margin="0,1,3,0" SnapsToDevicePixels="True"
                              Fill="{StaticResource Brush.BrandDelta}"
                              Data="M 9,0 L 18,16 H 0 Z M 9,5.6 L 13.3,13.2 H 4.7 Z" Stretch="None"/>
                        <!-- T cap height matched to the delta's 16px (Bahnschrift cap ≈ 0.72 em) -->
                        <TextBlock FontFamily="{StaticResource Font.Display}" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource Brush.Text}" VerticalAlignment="Center"
                                   Margin="-4,4,0,0" Text="T"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Module: the lead section container — ember overline + hairline rule +
         hazard ribbon, chamfered top-right corner, L-brackets. ONE lead module
         (or one matched pair) per screen; everything else uses Module.Quiet. -->
    <Style x:Key="Module" TargetType="HeaderedContentControl">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="HeaderedContentControl">
                    <controls:TechBorder Background="{StaticResource Brush.Panel}"
                                         BorderBrush="{StaticResource Brush.Stroke}"
                                         BorderThickness="1" CutTopRight="12"
                                         Brackets="True" BracketBrush="{StaticResource Brush.Bracket}" BracketLength="13"
                                         Padding="16,12,16,15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,13">
                                <TextBlock DockPanel.Dock="Left" Style="{StaticResource Text.Overline}"
                                           ui:Tracking.Text="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Rectangle DockPanel.Dock="Right" Width="42" Height="7"
                                           Fill="{StaticResource Brush.Hazard}" VerticalAlignment="Center"
                                           Margin="10,0,14,0"/>
                                <Rectangle Height="1" Fill="{StaticResource Brush.StrokeSoft}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <ContentPresenter Grid.Row="1"/>
                        </Grid>
                    </controls:TechBorder>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Module.Quiet: supporting sections. Same plate, but the title is quiet,
         the rule is bare, and there are no brackets or ribbon — hierarchy comes
         from withholding the signature, not repeating it. -->
    <Style x:Key="Module.Quiet" TargetType="HeaderedContentControl">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="HeaderedContentControl">
                    <controls:TechBorder Background="{StaticResource Brush.Panel}"
                                         BorderBrush="{StaticResource Brush.Stroke}"
                                         BorderThickness="1" CutTopRight="12"
                                         Padding="16,12,16,15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,13">
                                <TextBlock DockPanel.Dock="Left" Style="{StaticResource Text.Overline}"
                                           Foreground="{StaticResource Brush.TextDim}"
                                           ui:Tracking.Text="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Rectangle Height="1" Fill="{StaticResource Brush.StrokeSoft}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <ContentPresenter Grid.Row="1"/>
                        </Grid>
                    </controls:TechBorder>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================== buttons -->

    <!-- Ghost: outlined instrument button, mono caps; hover lights the edge ember. -->
    <Style x:Key="ButtonBase" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextDim}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{StaticResource Font.Mono}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="13,7"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <controls:TechBorder x:Name="bg" Background="{TemplateBinding Background}"
                                         BorderBrush="{TemplateBinding BorderBrush}"
                                         BorderThickness="{TemplateBinding BorderThickness}"
                                         CutTopRight="7" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </controls:TechBorder>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource Brush.PanelHigh}"/>
                            <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource Brush.AccentEdge}"/>
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource Brush.InputBg}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Filled ember plate — the one loud button per screen (the
         selected-plate language). -->
    <Style x:Key="Button.Primary" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
        <Setter Property="Background" Value="{StaticResource Brush.Accent}"/>
        <Setter Property="Foreground" Value="#FFF7EF"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <controls:TechBorder x:Name="bg" Background="{TemplateBinding Background}"
                                         BorderThickness="0" CutTopRight="8"
                                         Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </controls:TechBorder>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="#FF7E2E"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="#C9520F"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Button.Ghost" TargetType="Button" BasedOn="{StaticResource ButtonBase}"/>

    <!-- Bare ember text action (inline links). -->
    <Style x:Key="Button.Link" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
        <Setter Property="Foreground" Value="{StaticResource Brush.Accent}"/>
        <Setter Property="Padding" Value="2,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Brush.AccentBright}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window caption buttons -->
    <Style x:Key="Button.Caption" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="9.5"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextFaint}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource Brush.PanelHigh}"/>
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource Brush.AccentDim}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Top tab navigation: tracked DIN caps, ember underline when active
         (the console header tab). -->
    <Style x:Key="Button.Nav" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextDim}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid Background="Transparent" SnapsToDevicePixels="True">
                        <TextBlock ui:Tracking.Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                                   FontFamily="{StaticResource Font.Display}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{TemplateBinding Foreground}"
                                   VerticalAlignment="Center" Margin="15,0"/>
                        <Rectangle x:Name="bar" Height="2.5" Fill="{StaticResource Brush.Accent}"
                                   VerticalAlignment="Bottom" Margin="12,0" Opacity="0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bar" Property="Opacity" Value="1"/>
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.3"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Segmented selector: mono caps, ember underline on the active segment. -->
    <Style x:Key="Seg" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextDim}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid Background="Transparent">
                        <TextBlock x:Name="txt" Text="{TemplateBinding Content}"
                                   FontFamily="{StaticResource Font.Mono}" FontSize="11"
                                   Foreground="{TemplateBinding Foreground}"
                                   Margin="10,6,10,8"/>
                        <Rectangle x:Name="line" Height="2" Fill="{StaticResource Brush.Accent}"
                                   VerticalAlignment="Bottom" Margin="10,0" Opacity="0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="line" Property="Opacity" Value="1"/>
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================== scrollbars (thin, quiet) -->

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="7"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#3B2A1D" CornerRadius="2" Margin="1"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="7"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================== tooltips + context menu -->

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource Brush.PanelHigh}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Stroke}"/>
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <controls:TechBorder Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                         BorderThickness="1" CutTopRight="7" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </controls:TechBorder>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource Brush.PanelHigh}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Stroke}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <controls:TechBorder Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                         BorderThickness="1" CutTopRight="8" Padding="5">
                        <StackPanel IsItemsHost="True"/>
                    </controls:TechBorder>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="bg" Padding="11,7" Background="Transparent">
                        <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource Brush.AccentDim}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource Brush.Stroke}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="8,5"/>
    </Style>

    <!-- ============================== form controls -->

    <Style x:Key="Input" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Brush.InputBg}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Brush.Accent}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource Brush.Accent}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Stroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="9,5"/>
        <Setter Property="FontFamily" Value="{StaticResource Font.Mono}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource Brush.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Square check (filters, small options) -->
    <Style x:Key="Check" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextDim}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="box" Width="15" Height="15"
                                Background="{StaticResource Brush.InputBg}"
                                BorderBrush="{StaticResource Brush.Stroke}" BorderThickness="1"
                                VerticalAlignment="Center">
                            <Path x:Name="mark" Data="M 2.5,7.5 L 6,11 L 12.5,3.5"
                                  Stroke="{StaticResource Brush.Accent}" StrokeThickness="1.6"
                                  Opacity="0"/>
                        </Border>
                        <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Brush.TextFaint}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="mark" Property="Opacity" Value="1"/>
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Brush.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Toggle switch, squared off -->
    <Style x:Key="Toggle" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="track" Width="34" Height="18"
                                Background="{StaticResource Brush.InputBg}"
                                BorderBrush="{StaticResource Brush.Stroke}" BorderThickness="1"
                                VerticalAlignment="Center">
                            <Rectangle x:Name="thumb" Width="12" Height="12"
                                       Fill="{StaticResource Brush.TextFaint}"
                                       HorizontalAlignment="Left" Margin="2,0"/>
                        </Border>
                        <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="track" Property="Background" Value="{StaticResource Brush.AccentDim}"/>
                            <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource Brush.Accent}"/>
                            <Setter TargetName="thumb" Property="Fill" Value="{StaticResource Brush.Accent}"/>
                            <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Fader-style slider: thin track, bar thumb -->
    <Style x:Key="Fader" TargetType="Slider">
        <Setter Property="Height" Value="22"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <Border Height="3" Background="{StaticResource Brush.PanelHigh}" VerticalAlignment="Center"/>
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="3" Background="{StaticResource Brush.Accent}"
                                                    VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent" Height="22"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="6" Height="16">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Rectangle Fill="{StaticResource Brush.Accent}"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================== progress bar (thin load bar) -->

    <!-- Load is effort, not heat and not interaction — it reads bronze, so the
         thermal colors and the ember accent keep their meaning. -->
    <Style x:Key="LoadBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="3"/>
        <Setter Property="Background" Value="{StaticResource Brush.PanelHigh}"/>
        <Setter Property="Foreground" Value="#8A5A2C"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border Background="{TemplateBinding Background}"/>
                        <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                HorizontalAlignment="Left"/>
                        <Border x:Name="PART_Track"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
