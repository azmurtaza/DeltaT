<UserControl x:Class="DeltaT.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SettingRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="22,18,22,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ================= left column -->
                <StackPanel Grid.Column="0" Margin="0,0,7,0">

                    <HeaderedContentControl Style="{StaticResource Module}" Header="Location &amp; weather"
                                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" Text="{Binding LocationText}"/>
                            <TextBlock Style="{StaticResource Text.Dim}" FontSize="11" Margin="0,4,0,10"
                                       Text="Looked up once, then cached. The outside temperature re-fetches on the cadence below."/>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource Button.Primary}" Content="AUTO-DETECT"
                                        Command="{Binding AutoDetectCommand}"/>
                                <TextBox Style="{StaticResource Input}" Width="170" Margin="8,0"
                                         Text="{Binding CityQuery, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="OnCityKeyDown"
                                         ToolTip="Type a city, press Enter"/>
                                <Button Style="{StaticResource Button.Ghost}" Content="SEARCH"
                                        Command="{Binding SearchCityCommand}"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding CityResults}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource Button.Link}" HorizontalAlignment="Left"
                                                Command="{Binding DataContext.PickCityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock FontSize="12" Text="{Binding Display}"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Fixed indoor temperature: score rise against a set room temperature
                                 (climate-controlled rooms) instead of the outside weather. Each mode
                                 keeps its own baseline; the toggle switches between them. -->
                            <Grid Style="{StaticResource SettingRow}" Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                    <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" Text="Use a fixed indoor temperature"/>
                                    <TextBlock Style="{StaticResource Text.Dim}" FontSize="11" TextWrapping="Wrap"
                                               Text="For a climate-controlled room: score against a set indoor temperature, not the outside weather. Keeps its own baseline, so switching is safe."/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource Toggle}" VerticalAlignment="Center"
                                          IsChecked="{Binding IndoorFixedMode}"/>
                            </Grid>

                            <!-- Fixed temperature input (fixed mode only). Committed on Enter/blur so
                                 the fixed baseline relearns once per deliberate change, not per keystroke. -->
                            <Grid Style="{StaticResource SettingRow}" Margin="0,0,0,14"
                                  Visibility="{Binding IndoorFixedMode, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,14,0" VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" Text="Indoor temperature"/>
                                    <TextBlock Style="{StaticResource Text.Dim}" FontSize="11" TextWrapping="Wrap"
                                               Text="Your room's steady temperature. Changing it relearns the fixed baseline."/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBox Style="{StaticResource Input}" Width="82" TextAlignment="Right"
                                             Text="{Binding IndoorFixedTempDisplay, UpdateSourceTrigger=LostFocus, StringFormat=F1}"/>
                                    <TextBlock Style="{StaticResource Text.Numeral}" FontSize="12.5" MinWidth="26"
                                               Margin="8,0,0,0" VerticalAlignment="Center" Text="{Binding TempUnit}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Indoor offset (weather mode only): display-only nudge, hidden when a
                                 fixed indoor temperature is in charge. -->
                            <Grid Style="{StaticResource SettingRow}" Margin="0"
                                  Visibility="{Binding IndoorFixedMode, Converter={StaticResource InvBoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                    <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" Text="Indoor offset"/>
                                    <TextBlock Style="{StaticResource Text.Dim}" FontSize="11" TextWrapping="Wrap"
                                               Text="Room warmer/cooler than outside (AC, heating). Display only; scoring self-corrects."/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Slider Style="{StaticResource Fader}" Width="120" Minimum="-10" Maximum="8"
                                            TickFrequency="0.5" IsSnapToTickEnabled="True"
                                            Value="{Binding IndoorOffset}"/>
                                    <TextBlock Style="{StaticResource Text.Numeral}" FontSize="12.5" Width="44"
                                               Margin="10,0,0,0" VerticalAlignment="Center" TextAlignment="Right"
                                               Text="{Binding IndoorOffset, StringFormat='{}{0:+0.#;-0.#;0}°'}"/>
                                </StackPanel>
                            </Grid>
                            <Grid Style="{StaticResource SettingRow}" Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                    <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" Text="Weather refresh"/>
                                    <TextBlock Style="{StaticResource Text.Dim}" FontSize="11" TextWrapping="Wrap"
                                               Text="How often the outside temperature updates. Shorter for fast-swinging weather."/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <RadioButton x:Name="Ref1H" Style="{StaticResource Seg}" Content="1H" GroupName="refresh" Checked="OnRefresh1H"/>
                                    <RadioButton x:Name="Ref2H" Style="{StaticResource Seg}" Content="2H" GroupName="refresh" Checked="OnRefresh2H"/>
                                    <RadioButton x:Name="Ref3H" Style="{StaticResource Seg}" Content="3H" GroupName="refresh" Checked="OnRefresh3H"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </HeaderedContentControl>

                    <HeaderedContentControl Style="{StaticResource Module.Quiet}" Header="Behavior">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRow}">
                                <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" VerticalAlignment="Center"
                                           Text="Show temperatures in Fahrenheit"/>
                                <CheckBox Style="{StaticResource Toggle}" HorizontalAlignment="Right"
                                          IsChecked="{Binding Fahrenheit}"/>
                            </Grid>
                            <Grid Style="{StaticResource SettingRow}">
                                <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" VerticalAlignment="Center"
                                           Text="Show time in 12-hour format (AM/PM)"/>
                                <CheckBox Style="{StaticResource Toggle}" HorizontalAlignment="Right"
                                          IsChecked="{Binding TwelveHourClock}"/>
                            </Grid>
                            <Grid Style="{StaticResource SettingRow}">
                                <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" VerticalAlignment="Center"
                                           Text="Close button hides to tray (monitoring continues)"/>
                                <CheckBox Style="{StaticResource Toggle}" HorizontalAlignment="Right"
                                          IsChecked="{Binding CloseToTray}"/>
                            </Grid>
                            <Grid Style="{StaticResource SettingRow}">
                                <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" VerticalAlignment="Center"
                                           Text="Notify on warnings (throttling, degradation)"/>
                                <CheckBox Style="{StaticResource Toggle}" HorizontalAlignment="Right"
                                          IsChecked="{Binding NotificationsEnabled}"/>
                            </Grid>
                            <Grid Style="{StaticResource SettingRow}">
                                <StackPanel Margin="0,0,54,0">
                                    <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" Text="Background monitoring"/>
                                    <TextBlock Style="{StaticResource Text.Dim}" FontSize="11" TextWrapping="Wrap"
                                               Text="Sample sensors while DeltaT runs. Turn off to pause all polling; some rigs stutter in games when sensors are read constantly."/>
                                </StackPanel>
                                <CheckBox Style="{StaticResource Toggle}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                          IsChecked="{Binding CaptureEnabled}"/>
                            </Grid>
                            <Grid Style="{StaticResource SettingRow}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5"
                                               Text="Start with Windows"/>
                                    <TextBlock Style="{StaticResource Text.Dim}" FontSize="11"
                                               Text="Task Scheduler, elevated, no UAC prompt at logon"/>
                                </StackPanel>
                                <CheckBox Style="{StaticResource Toggle}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                          IsChecked="{Binding AutostartEnabled}" IsEnabled="{Binding AutostartAvailable}"/>
                            </Grid>
                            <Grid Style="{StaticResource SettingRow}" Margin="0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" Text="Sampling interval"/>
                                    <TextBlock Style="{StaticResource Text.Dim}" FontSize="11" Text="Applies on next launch"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <RadioButton x:Name="Int1" Style="{StaticResource Seg}" Content="1S" GroupName="ival" Checked="OnInterval1"/>
                                    <RadioButton x:Name="Int2" Style="{StaticResource Seg}" Content="2S" GroupName="ival" Checked="OnInterval2"/>
                                    <RadioButton x:Name="Int3" Style="{StaticResource Seg}" Content="3S" GroupName="ival" Checked="OnInterval3"/>
                                    <RadioButton x:Name="Int5" Style="{StaticResource Seg}" Content="5S" GroupName="ival" Checked="OnInterval5"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </HeaderedContentControl>

                </StackPanel>

                <!-- ================= right column -->
                <StackPanel Grid.Column="1" Margin="7,0,0,0">

                    <HeaderedContentControl Style="{StaticResource Module.Quiet}" Header="Baseline &amp; repaste"
                                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Dim}" FontSize="12" Margin="0,0,0,12"
                                       Text="Just repasted? Tell DeltaT. The baseline resets, and once the new one locks you get a before/after verdict, weather-corrected."/>
                            <Button Style="{StaticResource Button.Primary}" Content="I REPASTED THIS MACHINE"
                                    HorizontalAlignment="Left" Command="{Binding RegisterRepasteCommand}"/>
                            <TextBlock Style="{StaticResource Text.Dim}" FontSize="12" Margin="0,16,0,12"
                                       Text="Changed the cooling but not the paste (new fans, a clean-out, a moved rig), or DeltaT sat idle for months? Recalibrate to relearn the baseline. No before/after claim, just a fresh reference."/>
                            <Button Style="{StaticResource Button.Ghost}" Content="RECALIBRATE BASELINE"
                                    HorizontalAlignment="Left" Command="{Binding RecalibrateCommand}"/>
                        </StackPanel>
                    </HeaderedContentControl>

                    <HeaderedContentControl Style="{StaticResource Module.Quiet}" Header="Warning limits" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Dim}" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap"
                                       Text="Running hot on purpose? Set the sustained temperature DeltaT treats as too hot, so an overclock doesn't trip stock warnings. Drift against your own baseline is tracked regardless."/>
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource Text.Body}" FontSize="12.5"
                                           VerticalAlignment="Center" Text="CPU concern limit"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Slider Style="{StaticResource Fader}" Width="120" Minimum="70" Maximum="110"
                                            TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding CpuConcernC}"/>
                                    <TextBlock Style="{StaticResource Text.Numeral}" FontSize="12.5" Width="44"
                                               Margin="10,0,0,0" VerticalAlignment="Center" TextAlignment="Right"
                                               Text="{Binding CpuConcernC, StringFormat='{}{0:0}°'}"/>
                                </StackPanel>
                            </Grid>
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource Text.Body}" FontSize="12.5"
                                           VerticalAlignment="Center" Text="GPU concern limit"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Slider Style="{StaticResource Fader}" Width="120" Minimum="60" Maximum="105"
                                            TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding GpuConcernC}"/>
                                    <TextBlock Style="{StaticResource Text.Numeral}" FontSize="12.5" Width="44"
                                               Margin="10,0,0,0" VerticalAlignment="Center" TextAlignment="Right"
                                               Text="{Binding GpuConcernC, StringFormat='{}{0:0}°'}"/>
                                </StackPanel>
                            </Grid>
                            <Grid Style="{StaticResource SettingRow}" Margin="0">
                                <StackPanel Margin="0,0,54,0">
                                    <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5"
                                               Text="Warn near the silicon limit"/>
                                    <TextBlock Style="{StaticResource Text.Dim}" FontSize="11" TextWrapping="Wrap"
                                               Text="Flag peaks that sit right at TjMax. Turn off for a rig pinned there by design; real throttling still counts either way."/>
                                </StackPanel>
                                <CheckBox Style="{StaticResource Toggle}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                          IsChecked="{Binding HeadroomWarnings}"/>
                            </Grid>
                        </StackPanel>
                    </HeaderedContentControl>

                    <!-- Support lives in its own card, not buried in Feedback: not everyone
                         files a report, and a tip jar shouldn't hide behind one. A thin ember
                         edge and heart glyph catch the eye without a loud filled button. -->
                    <HeaderedContentControl Style="{StaticResource Module.Quiet}" Header="Support DeltaT">
                        <Border BorderBrush="{StaticResource Brush.Accent}" BorderThickness="1,0,0,0" Padding="12,2,0,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,14,0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Foreground="{StaticResource Brush.Accent}" FontSize="13"
                                                   VerticalAlignment="Center" Margin="0,0,7,0" Text="&#x2665;"/>
                                        <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" VerticalAlignment="Center"
                                                   Text="Free, no ads, no account."/>
                                    </StackPanel>
                                    <TextBlock Style="{StaticResource Text.Dim}" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap"
                                               Text="Built in spare time. If it earned its keep, a small tip keeps it improving. No pressure."/>
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource Button.Ghost}" Content="LEAVE A TIP"
                                        VerticalAlignment="Center" Click="OnSupportDeltaT"
                                        ToolTip="Binance Pay or USDT. Takes a few seconds, means a lot."/>
                            </Grid>
                        </Border>
                    </HeaderedContentControl>

                </StackPanel>

                <!-- ================= maintenance band: one uniform row across the
                     bottom (sensor driver / updates / data / feedback), so the page
                     ends level instead of trailing off in ragged blocks. The sensor
                     driver is a state, not a setting (DeltaT reads the CPU's thermal
                     registers through PawnIO; if it isn't there, say which readings
                     are missing and offer the fix), so it belongs among these small
                     status cards rather than dangling off the right column. -->
                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <HeaderedContentControl Grid.Column="0" Style="{StaticResource Module.Quiet}" Header="Sensor driver"
                                            Margin="0,0,7,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Dim}" FontSize="11.5" TextWrapping="Wrap"
                                       Text="{Binding SensorDriverText}"/>
                            <Button Style="{StaticResource Button.Ghost}" Content="INSTALL SENSOR DRIVER"
                                    HorizontalAlignment="Left" Margin="0,10,0,0"
                                    Command="{Binding InstallSensorDriverCommand}"
                                    Visibility="{Binding SensorDriverMissing, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </HeaderedContentControl>

                    <HeaderedContentControl Grid.Column="1" Style="{StaticResource Module.Quiet}" Header="Updates"
                                            Margin="7,0,7,0" Visibility="{Binding UpdatesAvailable, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                    <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" Text="Update automatically"/>
                                    <TextBlock Style="{StaticResource Text.Dim}" FontSize="11" TextWrapping="Wrap"
                                               Text="Install new versions from GitHub on startup."/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{StaticResource Toggle}" VerticalAlignment="Center"
                                          IsChecked="{Binding AutoUpdateEnabled}"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Style="{StaticResource Text.Dim}" FontSize="11" VerticalAlignment="Center"
                                           FontFamily="{StaticResource Font.Mono}"
                                           Text="{Binding CurrentVersionText, StringFormat='Current: {0}'}"/>
                                <Button Style="{StaticResource Button.Ghost}" Content="CHECK NOW"
                                        HorizontalAlignment="Right" Command="{Binding CheckForUpdatesCommand}"/>
                            </Grid>
                            <Button Style="{StaticResource Button.Link}" HorizontalAlignment="Left"
                                    Command="{Binding OpenProjectPageCommand}"
                                    ToolTip="github.com/deltat-app/DeltaT (latest installer and documentation)">
                                <TextBlock FontSize="11.5" Text="Project page, installer &amp; docs ↗"/>
                            </Button>
                        </StackPanel>
                    </HeaderedContentControl>

                    <HeaderedContentControl Grid.Column="2" Style="{StaticResource Module.Quiet}" Header="Data"
                                            Margin="7,0,7,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Dim}" FontSize="11"
                                       FontFamily="{StaticResource Font.Mono}" Text="{Binding DbText}"
                                       TextWrapping="Wrap"/>
                            <Button Style="{StaticResource Button.Ghost}" Content="EXPORT HISTORY AS CSV"
                                    HorizontalAlignment="Left" Margin="0,10,0,0"
                                    Command="{Binding ExportCsvCommand}"/>
                        </StackPanel>
                    </HeaderedContentControl>

                    <HeaderedContentControl Grid.Column="3" Style="{StaticResource Module.Quiet}" Header="Feedback"
                                            Margin="7,0,0,0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Dim}" FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap"
                                       Text="Bug or idea? It goes straight to the developer, no account needed. App version, Windows version, and PC model ride along."/>
                            <Button Style="{StaticResource Button.Ghost}" Content="REPORT A BUG OR IDEA"
                                    HorizontalAlignment="Left" Click="OnSendFeedback"/>
                        </StackPanel>
                    </HeaderedContentControl>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- status line -->
        <Border Grid.Row="1" Margin="0,12,0,0" Padding="2,10,0,0"
                BorderBrush="{StaticResource Brush.StrokeSoft}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderThickness" Value="0,1,0,0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusText}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Style="{StaticResource Text.Dim}" FontSize="12" Text="{Binding StatusText}"/>
        </Border>
    </Grid>
</UserControl>
