<UserControl x:Class="DeltaT.App.Views.RemarksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,16,28,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Style="{StaticResource Text.Caption}" Text="FIELD LOG"/>
                <TextBlock Style="{StaticResource Text.H1}" FontSize="17" Margin="0,5,0,0"
                           Text="Everything DeltaT noticed"/>
            </StackPanel>
            <CheckBox Style="{StaticResource Check}" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                      IsChecked="{Binding ImportantOnly}">
                <TextBlock Text="important only" Style="{StaticResource Text.Dim}" FontSize="12"/>
            </CheckBox>
        </Grid>

        <Border Grid.Row="1" BorderBrush="{StaticResource Brush.StrokeSoft}" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock Text="{Binding EmptyText}" Style="{StaticResource Text.Dim}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding Items.Count, Converter={StaticResource ZeroToVis}}"/>
                <ListBox ItemsSource="{Binding Items}" Background="Transparent" BorderThickness="0"
                         Padding="0" Margin="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="2,11" BorderThickness="0,0,0,1"
                                    BorderBrush="{StaticResource Brush.StrokeSoft}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Width="7" Height="7" RadiusX="1" RadiusY="1"
                                               Fill="{Binding Dot}" VerticalAlignment="Top" Margin="1,5,12,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5"
                                                   Text="{Binding Text}"/>
                                        <TextBlock Style="{StaticResource Text.Caption}" Margin="0,4,0,0"
                                                   Text="{Binding Badge}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Style="{StaticResource Text.Caption}"
                                               VerticalAlignment="Top" Margin="12,3,4,0"
                                               Text="{Binding TimeText}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
