<UserControl x:Class="DeltaT.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DeltaT.App.Controls"
             xmlns:ui="clr-namespace:DeltaT.App.Ui">

    <Grid Margin="22,18,22,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= hero: thermal diagnosis + overall dials + health matrix -->
        <controls:TechBorder Grid.Row="0" Style="{StaticResource Card}" Padding="22,16,22,16" Margin="0,0,0,14"
                             CutTopRight="14" Brackets="True" BracketBrush="{StaticResource Brush.Bracket}" BracketLength="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,28,0">
                        <TextBlock Style="{StaticResource Text.Overline}" ui:Tracking.Text="Thermal diagnosis"/>
                        <TextBlock Style="{StaticResource Text.Label}" Text="{Binding ScoringBasis}" Margin="0,5,0,0"/>
                        <TextBlock Style="{StaticResource Text.H1}" Text="{Binding VerdictTitle}" Margin="0,9,0,7"/>
                        <TextBlock Text="{Binding VerdictDetail}" FontSize="12.5" LineHeight="19">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Dim}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding VerdictDetail}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- the verdict's numbers as instrument readouts; each keeps its
                             full sentence as the tooltip -->
                        <ItemsControl ItemsSource="{Binding HeroStats}" Focusable="False" Margin="0,10,0,0"
                                      Visibility="{Binding HeroCalibrating, Converter={StaticResource InvBoolToVis}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Brush.StrokeSoft}" BorderThickness="1,0,0,0"
                                            Padding="14,1,0,0" Margin="0,0,22,0" Background="Transparent"
                                            ToolTip="{Binding Detail}" ToolTipService.ShowDuration="20000">
                                        <StackPanel>
                                            <TextBlock FontFamily="{StaticResource Font.DisplayCond}" FontSize="23" FontWeight="Bold"
                                                       Foreground="{Binding Brush}" Text="{Binding Value}"/>
                                            <TextBlock Style="{StaticResource Text.Caption}" Margin="0,3,0,0"
                                                       ui:Tracking.Text="{Binding Caption}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- while nothing is scored, the calibration confidence IS the reading:
                             a big numeral and a fill bar, not a percentage buried in prose -->
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,2"
                                    Visibility="{Binding HeroCalibrating, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontFamily="{StaticResource Font.DisplayCond}" FontSize="40" FontWeight="Bold"
                                       Foreground="{StaticResource Brush.Accent}" VerticalAlignment="Center"
                                       Text="{Binding CalibrationPercent}"/>
                            <StackPanel VerticalAlignment="Center" Margin="16,2,0,0" Width="250">
                                <TextBlock Style="{StaticResource Text.Caption}" ui:Tracking.Text="BASELINE CONFIDENCE"/>
                                <controls:SegmentBar Height="8" Margin="0,7,0,0"
                                                     Tint="{StaticResource Brush.Accent}"
                                                     Value="{Binding CalibrationPercentValue, Mode=OneWay}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- likely-cause chip: what's actually driving the temperature, not just how healthy -->
                        <Border Margin="0,12,0,0" Padding="12,8,12,9" Background="{StaticResource Brush.PanelHigh}"
                                BorderBrush="{Binding DiagnosisColor}" BorderThickness="2,0,0,0"
                                Visibility="{Binding HasDiagnosis, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock FontFamily="{StaticResource Font.Mono}" FontSize="10.5" FontWeight="SemiBold"
                                           Foreground="{Binding DiagnosisColor}" Text="{Binding DiagnosisHeadline}"/>
                                <TextBlock Style="{StaticResource Text.Dim}" FontSize="12" LineHeight="18"
                                           Margin="0,5,0,0" TextWrapping="Wrap" Text="{Binding DiagnosisText}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- the health instrument cluster: the two dials with their action
                         key beneath them — the controlled reading that feeds these
                         numbers lives with the numbers, not off in the prose column -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource Text.OverlineFaint}" HorizontalAlignment="Center"
                                   ui:Tracking.Text="Overall health"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <controls:ScoreDial Width="142" Height="142" Margin="8,2"
                                                Score="{Binding CpuScore.Value}"
                                                Calibrating="{Binding CpuScore.Calibrating}"
                                                Provisional="{Binding CpuScore.Provisional}"
                                                AwaitingData="{Binding CpuScore.AwaitingData}"
                                                Progress="{Binding CpuScore.Progress}"
                                                Verdict="{Binding CpuScore.VerdictShort}"
                                                Label="CPU"
                                                ToolTip="{Binding CpuScore.TopReason}"
                                                ToolTipService.IsEnabled="{Binding CpuScore.HasReason}"/>
                            <controls:ScoreDial Width="142" Height="142" Margin="8,2,0,2"
                                                Score="{Binding GpuScore.Value}"
                                                Calibrating="{Binding GpuScore.Calibrating}"
                                                Provisional="{Binding GpuScore.Provisional}"
                                                AwaitingData="{Binding GpuScore.AwaitingData}"
                                                Progress="{Binding GpuScore.Progress}"
                                                Verdict="{Binding GpuScore.VerdictShort}"
                                                Label="GPU"
                                                ToolTip="{Binding GpuScore.TopReason}"
                                                ToolTipService.IsEnabled="{Binding GpuScore.HasReason}"/>
                        </StackPanel>
                        <Button Margin="8,12,0,0" Padding="15,8" HorizontalAlignment="Stretch"
                                Click="OnRunFingerprint"
                                ToolTip="A controlled reading: idle settle, then full load on the CPU, the GPU, or both back to back. Repeatable month over month.">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
                                    <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentEdge}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M 0,0 L 7.5,4.5 L 0,9 Z" Fill="{StaticResource Brush.Accent}"
                                      VerticalAlignment="Center" Margin="0,1,10,0"/>
                                <TextBlock FontFamily="{StaticResource Font.Mono}" FontSize="11" FontWeight="SemiBold"
                                           ui:Tracking.Text="RUN FINGERPRINT TEST"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ===== the health matrix: every subsystem the engine judges, per component.
                     A healthy aspect reads as a visible 100, an unmeasurable one as dashes. -->
                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource Text.OverlineFaint}"
                                   ui:Tracking.Text="Health by subsystem · 100 = on baseline" Margin="0,0,10,0"/>
                        <Rectangle Height="1" Fill="{StaticResource Brush.StrokeSoft}" VerticalAlignment="Center"/>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Height="17"/>
                            <Border Height="34">
                                <TextBlock Style="{StaticResource Text.Caption}" Foreground="{StaticResource Brush.TextDim}"
                                           Text="CPU" VerticalAlignment="Center"/>
                            </Border>
                            <Border Height="34">
                                <TextBlock Style="{StaticResource Text.Caption}" Foreground="{StaticResource Brush.TextDim}"
                                           Text="GPU" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <ItemsControl Grid.Column="1" ItemsSource="{Binding AspectColumns}" Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,20,0">
                                        <Border Height="17">
                                            <TextBlock Style="{StaticResource Text.Caption}" VerticalAlignment="Top"
                                                       ui:Tracking.Text="{Binding Label}"/>
                                        </Border>
                                        <Grid Height="34" Background="Transparent" ToolTip="{Binding Cpu.Detail}">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock FontFamily="{StaticResource Font.DisplayCond}" FontSize="17" FontWeight="Bold"
                                                           Foreground="{Binding Cpu.ValueBrush}" Text="{Binding Cpu.Value}"/>
                                                <controls:SegmentBar Height="7" Margin="0,4,0,0"
                                                                     Tint="{Binding Cpu.ValueBrush}"
                                                                     Value="{Binding Cpu.BarValue, Mode=OneWay}"
                                                                     Visibility="{Binding Cpu.HasBar, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Height="34" Background="Transparent" ToolTip="{Binding Gpu.Detail}">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock FontFamily="{StaticResource Font.DisplayCond}" FontSize="17" FontWeight="Bold"
                                                           Foreground="{Binding Gpu.ValueBrush}" Text="{Binding Gpu.Value}"/>
                                                <controls:SegmentBar Height="7" Margin="0,4,0,0"
                                                                     Tint="{Binding Gpu.ValueBrush}"
                                                                     Value="{Binding Gpu.BarValue, Mode=OneWay}"
                                                                     Visibility="{Binding Gpu.HasBar, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>
            </Grid>
        </controls:TechBorder>

        <!-- sensor trust strip: only present when the readings can't be trusted
             (paused, stalled, or the CPU sensor is locked behind elevation) -->
        <Border Grid.Row="1" Margin="0,0,0,12" Padding="12,7"
                BorderBrush="{StaticResource Brush.HotWarn}" BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SensorNotice}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <Button DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0"
                        Content="RESTART AS ADMINISTRATOR"
                        Command="{Binding RestartAsAdminCommand}"
                        Visibility="{Binding ElevationOffered, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource Button.Primary}"/>
                <TextBlock FontFamily="{StaticResource Font.Mono}" FontSize="11"
                           Foreground="{StaticResource Brush.HotWarn}" TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Text="{Binding SensorNotice}"/>
            </DockPanel>
        </Border>

        <!-- ================= live telemetry ledger -->
        <HeaderedContentControl Grid.Row="2" Style="{StaticResource Module}" Header="Live telemetry">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- column captions: the reference is stated once, not per row -->
                <Grid Grid.Row="0" Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="178"/>
                        <ColumnDefinition Width="104"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource Text.Caption}" Text="COMPONENT"/>
                    <TextBlock Grid.Column="2" Style="{StaticResource Text.Caption}" Text="LOAD"/>
                    <TextBlock Grid.Column="3" Style="{StaticResource Text.Caption}" Text="TRACE · LAST 10 MIN"/>
                    <TextBlock Grid.Column="4" Style="{StaticResource Text.Caption}" Text="TEMPERATURE"
                               TextAlignment="Right"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0" Margin="0,0,-8,0">
                    <ItemsControl ItemsSource="{Binding Cards}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource Brush.StrokeSoft}" BorderThickness="0,0,0,1"
                                        Padding="0,8,0,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="178"/>
                                            <ColumnDefinition Width="104"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- identity -->
                                        <controls:ComponentGlyph Grid.Column="0" Width="18" Height="18"
                                                                 VerticalAlignment="Center" Margin="0,0,12,0"
                                                                 Kind="{Binding Badge}"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <TextBlock FontFamily="{StaticResource Font.Display}" FontSize="14"
                                                       FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}"
                                                       ui:Tracking.Text="{Binding Badge}"/>
                                            <TextBlock Style="{StaticResource Text.Caption}" Margin="0,4,0,0"
                                                       Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- load -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,22,0">
                                            <ProgressBar Style="{StaticResource LoadBar}"
                                                         Minimum="0" Maximum="100" Value="{Binding Load, Mode=OneWay}"/>
                                            <TextBlock Style="{StaticResource Text.Caption}" Margin="0,7,0,0"
                                                       Text="{Binding LoadText}"/>
                                        </StackPanel>

                                        <!-- trace -->
                                        <Grid Grid.Column="3" Margin="0,0,22,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <controls:Sparkline Grid.Row="0" Height="30" VerticalAlignment="Bottom"
                                                                Values="{Binding Spark}"/>
                                            <TextBlock Grid.Row="1" Style="{StaticResource Text.Caption}" Margin="0,6,0,0"
                                                       Text="{Binding MetaText}" TextTrimming="CharacterEllipsis"/>
                                        </Grid>

                                        <!-- reading -->
                                        <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock TextAlignment="Right"
                                                       Foreground="{Binding RawFraction, Converter={StaticResource FracToBrush}}"
                                                       Visibility="{Binding HasTemp, Converter={StaticResource BoolToVis}}">
                                                <Run FontFamily="{StaticResource Font.DisplayCond}" FontSize="28" FontWeight="Bold"
                                                     Text="{Binding Temp, Mode=OneWay, StringFormat='{}{0:0.0}'}"/><Run
                                                     FontFamily="{StaticResource Font.Mono}" FontSize="12"
                                                     Foreground="{StaticResource Brush.TextDim}"
                                                     Text="{Binding Unit, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock TextAlignment="Right" FontFamily="{StaticResource Font.DisplayCond}"
                                                       FontSize="28" FontWeight="Bold"
                                                       Foreground="{StaticResource Brush.TextFaint}" Text="-"
                                                       Visibility="{Binding HasTemp, Converter={StaticResource InvBoolToVis}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </HeaderedContentControl>

        <!-- ================= latest remark: an instrument event line, not loose text.
             Severity LED + tag on a panel strip; the full feed lives on the Remarks tab. -->
        <controls:TechBorder Grid.Row="3" Margin="0,12,0,0" Padding="12,7,12,7" CutTopRight="8"
                             Background="{StaticResource Brush.Panel}"
                             BorderBrush="{StaticResource Brush.Stroke}" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Rectangle Width="6" Height="6" VerticalAlignment="Center" Fill="{Binding RemarkDot}"/>
                    <TextBlock Margin="9,0,0,0" VerticalAlignment="Center" FontFamily="{StaticResource Font.Mono}"
                               FontSize="9.5" FontWeight="SemiBold" Width="76"
                               Foreground="{Binding RemarkDot}" ui:Tracking.Text="{Binding LatestRemarkTag}"/>
                    <Rectangle Width="1" Fill="{StaticResource Brush.StrokeSoft}" Margin="2,1,12,1"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Margin="14,0,0,0" VerticalAlignment="Center"
                           Style="{StaticResource Text.Caption}" Text="{Binding LatestRemarkTime}"/>
                <TextBlock VerticalAlignment="Center"
                           Style="{StaticResource Text.Dim}" FontSize="12.5"
                           Text="{Binding LatestRemark}" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </controls:TechBorder>
    </Grid>
</UserControl>
