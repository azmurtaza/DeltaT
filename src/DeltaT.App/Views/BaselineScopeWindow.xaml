<Window x:Class="DeltaT.App.Views.BaselineScopeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ui="clr-namespace:DeltaT.App.Ui"
        Title="DeltaT" Width="460" SizeToContent="Height"
        Icon="pack://application:,,,/Assets/deltat.ico"
        Background="{StaticResource Brush.BgGlow}" Foreground="{StaticResource Brush.Text}"
        FontFamily="{StaticResource Font.Ui}" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" ResizeBorderThickness="0"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Rectangle Grid.RowSpan="2" Fill="{StaticResource Brush.BgDots}"/>

        <!-- chrome bar -->
        <Border Grid.Row="0" Background="{StaticResource Brush.Rail}"
                BorderBrush="{StaticResource Brush.StrokeSoft}" BorderThickness="0,0,0,1">
            <DockPanel Margin="16,0,4,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <ContentControl Style="{StaticResource Brand.Mark}"/>
                    <Rectangle Width="22" Height="7" Fill="{StaticResource Brush.Hazard}"
                               VerticalAlignment="Center" Margin="11,1,0,0"/>
                    <Rectangle Width="1" Fill="{StaticResource Brush.Stroke}" Margin="14,7"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource Button.Caption}" Content="&#xE8BB;"
                        Click="OnCancel" ToolTip="Close"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <TextBlock x:Name="Overline" Style="{StaticResource Text.OverlineFaint}"
                           VerticalAlignment="Center" Margin="0,1,0,0"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="30,18,30,22">
            <StackPanel>
                <TextBlock x:Name="Heading" Style="{StaticResource Text.H1}" FontSize="19" Margin="0,2,0,8"/>
                <TextBlock x:Name="Blurb" Style="{StaticResource Text.Body}" FontSize="12.5"
                           LineHeight="19" TextWrapping="Wrap"/>

                <TextBlock Style="{StaticResource Text.OverlineFaint}" Margin="0,18,0,8"
                           ui:Tracking.Text="WHICH COMPONENT?"/>

                <RadioButton x:Name="ScopeBoth" Style="{StaticResource Choice}" GroupName="Scope" IsChecked="True" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock x:Name="BothLabel" Style="{StaticResource Text.Body}" FontSize="12.5"/>
                        <TextBlock x:Name="BothHint" Style="{StaticResource Text.Dim}" FontSize="11"
                                   LineHeight="16" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="ScopeCpu" Style="{StaticResource Choice}" GroupName="Scope" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock x:Name="CpuLabel" Style="{StaticResource Text.Body}" FontSize="12.5"/>
                        <TextBlock x:Name="CpuHint" Style="{StaticResource Text.Dim}" FontSize="11"
                                   LineHeight="16" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="ScopeGpu" Style="{StaticResource Choice}" GroupName="Scope">
                    <StackPanel>
                        <TextBlock x:Name="GpuLabel" Style="{StaticResource Text.Body}" FontSize="12.5"/>
                        <TextBlock x:Name="GpuHint" Style="{StaticResource Text.Dim}" FontSize="11"
                                   LineHeight="16" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </RadioButton>

                <TextBlock x:Name="Footnote" Style="{StaticResource Text.Dim}" FontSize="11" LineHeight="16"
                           Margin="0,16,0,0" TextWrapping="Wrap"
                           Text="Whatever you leave out keeps the baseline it already earned, along with its score and its history."/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Style="{StaticResource Button.Ghost}" Content="CANCEL" Click="OnCancel"/>
                    <Button x:Name="ConfirmButton" Style="{StaticResource Button.Primary}"
                            Margin="10,0,0,0" Click="OnConfirm" IsDefault="True"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
