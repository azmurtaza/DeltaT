<Window x:Class="DeltaT.App.Views.DonateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ui="clr-namespace:DeltaT.App.Ui"
        Title="DeltaT - support" Width="440" Height="660"
        Icon="pack://application:,,,/Assets/deltat.ico"
        Background="{StaticResource Brush.BgGlow}" Foreground="{StaticResource Brush.Text}"
        FontFamily="{StaticResource Font.Ui}" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" ResizeBorderThickness="0"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Rectangle Grid.RowSpan="2" Fill="{StaticResource Brush.BgDots}"/>

        <!-- chrome bar -->
        <Border Grid.Row="0" Background="{StaticResource Brush.Rail}"
                BorderBrush="{StaticResource Brush.StrokeSoft}" BorderThickness="0,0,0,1">
            <DockPanel Margin="16,0,4,0">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <ContentControl Style="{StaticResource Brand.Mark}"/>
                    <Rectangle Width="22" Height="7" Fill="{StaticResource Brush.Hazard}"
                               VerticalAlignment="Center" Margin="11,1,0,0"/>
                    <Rectangle Width="1" Fill="{StaticResource Brush.Stroke}" Margin="14,7"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource Button.Caption}" Content="&#xE8BB;"
                        Click="OnCloseChrome" ToolTip="Close"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <TextBlock Style="{StaticResource Text.OverlineFaint}" VerticalAlignment="Center"
                           Margin="0,1,0,0" ui:Tracking.Text="SUPPORT DELTAT"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="30,18,30,22">
            <StackPanel>
                <TextBlock Style="{StaticResource Text.H1}" FontSize="20" Text="Support DeltaT" Margin="0,2,0,8"/>
                <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" LineHeight="19" TextWrapping="Wrap"
                           Text="DeltaT is free and built in my spare time. If it earned its keep, a small tip helps me keep improving it. No pressure, and thank you either way."/>

                <!-- Primary: Binance Pay. QR on a white plate so any phone scans it cleanly. -->
                <Border HorizontalAlignment="Center" Margin="0,18,0,8" Padding="12"
                        Background="White" CornerRadius="0"
                        BorderBrush="{StaticResource Brush.Stroke}" BorderThickness="1">
                    <Image x:Name="QrCode" Width="184" Height="184" Stretch="Fill"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </Border>
                <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" HorizontalAlignment="Center"
                           Text="Scan to pay with Binance Pay"/>
                <TextBlock Style="{StaticResource Text.Dim}" FontSize="11" HorizontalAlignment="Center"
                           Margin="0,2,0,0" Text="Any coin, no network to pick, no fee."/>

                <!-- Binance Pay UID (manual fallback for the QR) -->
                <TextBlock Style="{StaticResource Text.OverlineFaint}" ui:Tracking.Text="OR BY BINANCE PAY UID" Margin="0,16,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource Brush.Rail}"
                            BorderBrush="{StaticResource Brush.StrokeSoft}" BorderThickness="1"
                            Padding="10,7" VerticalAlignment="Center">
                        <TextBlock x:Name="UidText" Style="{StaticResource Text.Body}" FontSize="12.5"
                                   FontFamily="{StaticResource Font.Mono}"/>
                    </Border>
                    <Button Grid.Column="1" Style="{StaticResource Button.Ghost}" Content="COPY"
                            Margin="8,0,0,0" VerticalAlignment="Center" Click="OnCopyUid"/>
                </Grid>

                <!-- Fallback: USDT TRC20 for donors not on Binance -->
                <Border Height="1" Background="{StaticResource Brush.StrokeSoft}" Margin="0,16,0,0"/>
                <TextBlock Style="{StaticResource Text.OverlineFaint}" ui:Tracking.Text="NOT ON BINANCE?  USDT · TRON (TRC20)" Margin="0,14,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource Brush.Rail}"
                            BorderBrush="{StaticResource Brush.StrokeSoft}" BorderThickness="1"
                            Padding="10,7" VerticalAlignment="Center">
                        <TextBlock x:Name="AddressText" Style="{StaticResource Text.Body}" FontSize="11.5"
                                   FontFamily="{StaticResource Font.Mono}" TextWrapping="Wrap"/>
                    </Border>
                    <Button Grid.Column="1" Style="{StaticResource Button.Ghost}" Content="COPY"
                            Margin="8,0,0,0" VerticalAlignment="Center" Click="OnCopyAddress"/>
                </Grid>
                <TextBlock Style="{StaticResource Text.Dim}" FontSize="11" LineHeight="16" Margin="0,8,0,0" TextWrapping="Wrap"
                           Text="Send only USDT on the TRON (TRC20) network to this address. A different coin or network will not arrive."/>

                <TextBlock x:Name="StatusText" Foreground="{StaticResource Brush.Accent}" FontSize="12"
                           Margin="0,10,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
