<Window x:Class="DeltaT.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ui="clr-namespace:DeltaT.App.Ui"
        Title="DeltaT" Width="1040" Height="740" MinWidth="840" MinHeight="620"
        Icon="pack://application:,,,/Assets/deltat.ico"
        Background="{StaticResource Brush.BgGlow}"
        Foreground="{StaticResource Brush.Text}"
        FontFamily="{StaticResource Font.Ui}"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="6"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.Style>
            <!-- Maximized custom-chrome windows overshoot the work area by the
                 resize border; pull the content back in. -->
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}"
                                 Value="Maximized">
                        <Setter Property="Margin" Value="7"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- faint graph-paper dots over the ember glow -->
        <Rectangle Grid.Row="0" Grid.RowSpan="2" Fill="{StaticResource Brush.BgDots}"/>

        <!-- ============================ header bar: brand + tabs + status -->
        <Border Grid.Row="0" Background="{StaticResource Brush.Rail}"
                BorderBrush="{StaticResource Brush.StrokeSoft}" BorderThickness="0,0,0,1">
            <DockPanel Margin="18,0,6,0">

                <!-- wordmark -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="{StaticResource Font.Display}" FontSize="21" FontWeight="Bold"
                               VerticalAlignment="Center">
                        <Run Text="Δ" Foreground="{StaticResource Brush.Accent}"/><Run Text="T" Foreground="{StaticResource Brush.Text}"/>
                    </TextBlock>
                    <Rectangle Width="26" Height="7" Fill="{StaticResource Brush.Hazard}"
                               VerticalAlignment="Center" Margin="12,1,0,0"/>
                    <Rectangle Width="1" Fill="{StaticResource Brush.Stroke}" Margin="16,13"/>
                </StackPanel>

                <!-- right: weather + sim chip + caption buttons (machine identity
                     lives on the Device page — the bar stays clean) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource Chip}" Margin="0,0,14,0" VerticalAlignment="Center"
                            Background="{StaticResource Brush.AccentDim}" BorderBrush="{StaticResource Brush.AccentEdge}"
                            Visibility="{Binding Simulated, Converter={StaticResource BoolToVis}}">
                        <TextBlock FontSize="9.5" FontFamily="{StaticResource Font.Mono}"
                                   Foreground="{StaticResource Brush.Accent}" Text="SIMULATED"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0"
                                ToolTip="{Binding WeatherTooltip}" Background="Transparent"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Rectangle Width="6" Height="6" VerticalAlignment="Center" Margin="0,1,7,0">
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Setter Property="Fill" Value="{StaticResource Brush.Accent}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WeatherStale}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource Brush.Hot}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>
                        <TextBlock FontSize="11" FontFamily="{StaticResource Font.Mono}"
                                   Foreground="{StaticResource Brush.TextDim}"
                                   Text="{Binding WeatherText}"/>
                    </StackPanel>

                    <Button Style="{StaticResource Button.Caption}" Content="&#xE921;"
                            Click="OnMinimize" ToolTip="Minimize"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Click="OnMaxRestore" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource Button.Caption}">
                                <Setter Property="Content" Value="&#xE922;"/>
                                <Setter Property="ToolTip" Value="Maximize"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="Maximized">
                                        <Setter Property="Content" Value="&#xE923;"/>
                                        <Setter Property="ToolTip" Value="Restore"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Style="{StaticResource Button.Caption}" Content="&#xE8BB;"
                            Click="OnClose" ToolTip="Close to tray"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>

                <!-- nav tabs: caps + ember underline -->
                <StackPanel x:Name="NavPanel" Orientation="Horizontal" VerticalAlignment="Stretch"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <RadioButton x:Name="NavDashboard" Style="{StaticResource Button.Nav}" Content="Dashboard"
                                 IsChecked="True" GroupName="nav" Checked="OnNavDashboard"/>
                    <RadioButton x:Name="NavTrends" Style="{StaticResource Button.Nav}" Content="Trends"
                                 GroupName="nav" Checked="OnNavTrends"/>
                    <RadioButton x:Name="NavDevice" Style="{StaticResource Button.Nav}" Content="Device"
                                 GroupName="nav" Checked="OnNavDevice"/>
                    <RadioButton x:Name="NavRemarks" Style="{StaticResource Button.Nav}" Content="Remarks"
                                 GroupName="nav" Checked="OnNavRemarks"/>
                    <RadioButton x:Name="NavSettings" Style="{StaticResource Button.Nav}" Content="Settings"
                                 GroupName="nav" Checked="OnNavSettings"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================ body -->
        <ContentControl x:Name="ContentHost" Grid.Row="1"/>
    </Grid>
</Window>
