<Window x:Class="DeltaT.App.Views.FingerprintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:DeltaT.App.Controls"
        xmlns:ui="clr-namespace:DeltaT.App.Ui"
        Title="DeltaT — thermal fingerprint" Width="520" Height="580"
        Icon="pack://application:,,,/Assets/deltat.ico"
        Background="{StaticResource Brush.BgGlow}" Foreground="{StaticResource Brush.Text}"
        FontFamily="{StaticResource Font.Ui}" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" ResizeBorderThickness="0"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Rectangle Grid.RowSpan="2" Fill="{StaticResource Brush.BgDots}"/>

        <!-- chrome bar: same language as the main window -->
        <Border Grid.Row="0" Background="{StaticResource Brush.Rail}"
                BorderBrush="{StaticResource Brush.StrokeSoft}" BorderThickness="0,0,0,1">
            <DockPanel Margin="16,0,4,0">
                <TextBlock DockPanel.Dock="Left" FontFamily="{StaticResource Font.Display}"
                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center">
                    <Run Text="Δ" Foreground="{StaticResource Brush.Accent}"/><Run Text="T" Foreground="{StaticResource Brush.Text}"/>
                </TextBlock>
                <Button DockPanel.Dock="Right" Style="{StaticResource Button.Caption}" Content="&#xE8BB;"
                        Click="OnCloseChrome" ToolTip="Close"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <TextBlock Style="{StaticResource Text.OverlineFaint}" VerticalAlignment="Center"
                           Margin="14,1,0,0" ui:Tracking.Text="THERMAL FINGERPRINT"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="30,20,30,24">

        <!-- ============ intro ============ -->
        <StackPanel Visibility="{Binding State, Converter={StaticResource StateToVis}, ConverterParameter=intro}">
            <TextBlock Style="{StaticResource Text.H1}" Text="A 3-minute honest look" Margin="0,4,0,10"/>
            <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" LineHeight="19" TextWrapping="Wrap">
                DeltaT idles for 25 seconds, then loads every CPU core for 2½ minutes and watches:
                how fast the heat soaks in, where it settles, and whether the silicon has to throttle.
                Same test, same numbers — run it monthly and the drift <Run FontStyle="Italic">is</Run> your paste aging.
            </TextBlock>
            <StackPanel Margin="0,16,0,0">
                <TextBlock Style="{StaticResource Text.OverlineFaint}" ui:Tracking.Text="BEFORE YOU START"/>
                <TextBlock Style="{StaticResource Text.Dim}" FontSize="12" LineHeight="19" Margin="0,6,0,0" TextWrapping="Wrap"
                           Text="Plug in the charger; battery runs aren't comparable. Close heavy apps so the idle phase is actually idle. Fans will spin up — that's the point."/>
            </StackPanel>
            <Border Background="{StaticResource Brush.PanelHigh}" BorderBrush="{StaticResource Brush.Warm}"
                    BorderThickness="2,0,0,0"
                    Padding="12,9" Margin="0,16,0,0"
                    Visibility="{Binding OnBattery, Converter={StaticResource BoolToVis}}">
                <TextBlock FontSize="12" Foreground="{StaticResource Brush.Warm}"
                           Text="You're on battery right now — results will be recorded but flagged."/>
            </Border>
            <Button Style="{StaticResource Button.Primary}" Content="START THE TEST" Padding="20,10"
                    HorizontalAlignment="Left" Margin="0,22,0,0"
                    Command="{Binding StartCommand}"/>
        </StackPanel>

        <!-- ============ running ============ -->
        <Grid Visibility="{Binding State, Converter={StaticResource StateToVis}, ConverterParameter=running}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <TextBlock Style="{StaticResource Text.Overline}" ui:Tracking.Text="Fingerprint in progress"/>
                <TextBlock Style="{StaticResource Text.H1}" FontSize="18" Text="{Binding Phase}" Margin="0,9,0,0"/>
                <TextBlock Style="{StaticResource Text.Dim}" FontSize="12" Margin="0,4,0,0"
                           Text="{Binding SecondsLeft, StringFormat='{}{0:0} s remaining in this phase'}"/>
            </StackPanel>
            <controls:RingGauge Grid.Row="1" Width="230" Height="230"
                                Value="{Binding CurrentTemp}" Maximum="100"
                                HasValue="{Binding HasCurrentTemp}" Unit="°C" SubText="CPU"/>
            <Button Grid.Row="2" Style="{StaticResource Button.Ghost}" Content="STOP THE TEST"
                    HorizontalAlignment="Center" Foreground="{StaticResource Brush.Hot}"
                    Command="{Binding StopCommand}"/>
        </Grid>

        <!-- ============ done ============ -->
        <StackPanel Visibility="{Binding State, Converter={StaticResource StateToVis}, ConverterParameter=done}">
            <TextBlock Style="{StaticResource Text.Overline}" ui:Tracking.Text="Fingerprint result"/>
            <ItemsControl ItemsSource="{Binding ResultCells}" Margin="0,16,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource Brush.StrokeSoft}" BorderThickness="1,0,0,0"
                                Padding="12,4,0,10" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Text.Caption}" Text="{Binding Label}"/>
                                <TextBlock Style="{StaticResource Text.Display}" FontSize="19"
                                           Margin="0,5,0,0" Text="{Binding Value}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Border Style="{StaticResource Card}" Margin="0,12,0,0" Padding="16,13">
                <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" LineHeight="19"
                           Text="{Binding VerdictText}" TextWrapping="Wrap"/>
            </Border>
            <Button Style="{StaticResource Button.Primary}" Content="DONE" Padding="22,9"
                    HorizontalAlignment="Left" Margin="0,18,0,0" Click="OnDone"/>
        </StackPanel>
        </Grid>
    </Grid>
</Window>
