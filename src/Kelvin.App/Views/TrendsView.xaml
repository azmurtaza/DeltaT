<UserControl x:Class="Kelvin.App.Views.TrendsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Kelvin.App.Controls">
    <UserControl.Resources>
        <Style x:Key="Pill" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextDim}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" CornerRadius="99" Padding="14,6" Background="Transparent">
                            <TextBlock Text="{TemplateBinding Content}" FontFamily="{StaticResource Font.Mono}"
                                       FontSize="11.5" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#141C26"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource Brush.AccentDim}"/>
                                <Setter Property="Foreground" Value="{StaticResource Brush.Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="22,14,22,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- selector row -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <RadioButton Style="{StaticResource Pill}" Content="CPU" GroupName="kind" IsChecked="True" Checked="OnKind0"/>
                <RadioButton Style="{StaticResource Pill}" Content="GPU" GroupName="kind" Checked="OnKind1" Margin="4,0,0,0"/>
                <RadioButton Style="{StaticResource Pill}" Content="SSD" GroupName="kind" Checked="OnKind2" Margin="4,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <RadioButton Style="{StaticResource Pill}" Content="24h" GroupName="range" IsChecked="True"
                             Command="{Binding SetRangeCommand}" CommandParameter="24h"/>
                <RadioButton Style="{StaticResource Pill}" Content="7d" GroupName="range" Margin="4,0,0,0"
                             Command="{Binding SetRangeCommand}" CommandParameter="7d"/>
                <RadioButton Style="{StaticResource Pill}" Content="30d" GroupName="range" Margin="4,0,0,0"
                             Command="{Binding SetRangeCommand}" CommandParameter="30d"/>
                <RadioButton Style="{StaticResource Pill}" Content="all" GroupName="range" Margin="4,0,0,0"
                             Command="{Binding SetRangeCommand}" CommandParameter="all"/>
            </StackPanel>
        </Grid>

        <!-- chart -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="4,0,0,6">
                    <Rectangle Width="14" Height="2.5" Fill="{StaticResource Brush.Accent}" VerticalAlignment="Center"/>
                    <TextBlock Style="{StaticResource Text.Caption}" Text="COMPONENT" Margin="6,0,16,0"/>
                    <Rectangle Width="14" Height="2" VerticalAlignment="Center">
                        <Rectangle.Fill>
                            <DrawingBrush TileMode="Tile" Viewport="0,0,6,2" ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing Brush="#8B98A5" Geometry="M0,0 H3 V2 H0Z"/>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <TextBlock Style="{StaticResource Text.Caption}" Text="OUTSIDE" Margin="6,0,16,0"/>
                    <TextBlock Style="{StaticResource Text.Caption}" Text="R = REPASTE   F = FINGERPRINT   T = THROTTLE"/>
                </StackPanel>
                <controls:TimeSeriesChart Grid.Row="1"
                                          Points="{Binding Points}"
                                          AmbientPoints="{Binding AmbientPoints}"
                                          Markers="{Binding Markers}"/>
            </Grid>
        </Border>

        <!-- stats strip -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Stats}" Margin="-5,10,-5,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Margin="5,0" Padding="14,10">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text.Caption}" Text="{Binding Label}"/>
                            <TextBlock Style="{StaticResource Text.Numeral}" FontSize="20" Margin="0,4,0,0"
                                       Text="{Binding Value}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
