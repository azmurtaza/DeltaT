<Window x:Class="Kelvin.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:Kelvin.App.Views"
        Title="Kelvin" Width="1000" Height="720" MinWidth="780" MinHeight="580"
        Background="{StaticResource Brush.Bg}"
        Foreground="{StaticResource Brush.Text}"
        FontFamily="{StaticResource Font.Ui}"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="6"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <!-- faint blueprint grid under everything -->
        <Rectangle Fill="{StaticResource Brush.BlueprintGrid}"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ============================ title bar -->
            <Grid Grid.Row="0" Margin="18,0,6,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="{StaticResource Font.Mono}" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource Brush.Text}">
                        <Run Text="K E L V I N"/><Run Text="°" Foreground="{StaticResource Brush.Accent}"/>
                    </TextBlock>
                    <Border Style="{StaticResource Chip}" Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="11" Foreground="{StaticResource Brush.TextDim}">
                            <Run Text="{Binding MachineName, Mode=OneWay}"/>
                            <Run Text=" · " Foreground="{StaticResource Brush.TextFaint}"/>
                            <Run Text="{Binding ProfileName, Mode=OneWay}" Foreground="{StaticResource Brush.TextFaint}"/>
                        </TextBlock>
                    </Border>
                    <Border Style="{StaticResource Chip}" Margin="8,0,0,0" VerticalAlignment="Center"
                            Background="#1A1206" BorderBrush="#3A2A0A"
                            Visibility="{Binding Simulated, Converter={StaticResource BoolToVis}}">
                        <TextBlock FontSize="11" FontFamily="{StaticResource Font.Mono}"
                                   Foreground="{StaticResource Brush.Warm}" Text="SIMULATED"/>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Style="{StaticResource Chip}" VerticalAlignment="Center"
                            ToolTip="{Binding WeatherTooltip}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,1,7,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource Brush.Cool}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WeatherStale}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource Brush.Warm}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock FontSize="11.5" FontFamily="{StaticResource Font.Mono}"
                                       Foreground="{StaticResource Brush.TextDim}"
                                       Text="{Binding WeatherText}"/>
                        </StackPanel>
                    </Border>

                    <Button Style="{StaticResource Button.Caption}" Content="&#xE921;" Margin="10,0,0,0"
                            Click="OnMinimize" ToolTip="Minimize"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Style="{StaticResource Button.Caption}" Content="&#xE8BB;"
                            Click="OnClose" ToolTip="Close to tray"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>
            </Grid>

            <!-- ============================ body -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- nav rail -->
                <Border Grid.Column="0" Background="#0D1218" BorderBrush="{StaticResource Brush.StrokeSoft}"
                        BorderThickness="0,0,1,0">
                    <StackPanel Margin="0,10,0,0">
                        <RadioButton x:Name="NavDashboard" Style="{StaticResource Button.Nav}" Content="&#xE80F;"
                                     Tag="Dashboard" IsChecked="True" GroupName="nav"/>
                        <RadioButton x:Name="NavTrends" Style="{StaticResource Button.Nav}" Content="&#xE81C;"
                                     Tag="Trends" GroupName="nav" IsEnabled="False"/>
                        <RadioButton x:Name="NavRemarks" Style="{StaticResource Button.Nav}" Content="&#xE8BD;"
                                     Tag="Remarks" GroupName="nav" IsEnabled="False"/>
                        <RadioButton x:Name="NavSettings" Style="{StaticResource Button.Nav}" Content="&#xE713;"
                                     Tag="Settings" GroupName="nav" IsEnabled="False"/>
                    </StackPanel>
                </Border>

                <ContentControl x:Name="ContentHost" Grid.Column="1">
                    <views:DashboardView/>
                </ContentControl>
            </Grid>
        </Grid>
    </Grid>
</Window>
