<UserControl x:Class="Kelvin.App.Views.RemarksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="22,14,22,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource Text.H1}" Text="Everything Kelvin noticed" FontSize="17"/>
            </StackPanel>
            <CheckBox HorizontalAlignment="Right" VerticalAlignment="Center"
                      IsChecked="{Binding ImportantOnly}"
                      Foreground="{StaticResource Brush.TextDim}" FontSize="12">
                <TextBlock Text="important only" Style="{StaticResource Text.Dim}" FontSize="12"/>
            </CheckBox>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
            <Grid>
                <TextBlock Text="{Binding EmptyText}" Style="{StaticResource Text.Dim}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding Items.Count, Converter={StaticResource ZeroToVis}}"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14,10" BorderThickness="0,0,0,1"
                                        BorderBrush="{StaticResource Brush.StrokeSoft}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="7" Height="7" Fill="{Binding Dot}"
                                                 VerticalAlignment="Top" Margin="0,5,11,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5"
                                                       Text="{Binding Text}"/>
                                            <TextBlock Style="{StaticResource Text.Caption}" Margin="0,4,0,0"
                                                       Text="{Binding Badge}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Style="{StaticResource Text.Caption}"
                                                   VerticalAlignment="Top" Margin="10,3,4,0"
                                                   Text="{Binding TimeText}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
