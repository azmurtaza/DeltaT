<UserControl x:Class="Kelvin.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Kelvin.App.Controls">

    <Grid Margin="22,14,22,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= hero: verdict + paste dials -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,18,0">
                    <TextBlock Style="{StaticResource Text.Caption}" Text="PASTE VERDICT"/>
                    <TextBlock Style="{StaticResource Text.H1}" Text="{Binding VerdictTitle}" Margin="0,7,0,5"/>
                    <TextBlock Style="{StaticResource Text.Dim}" Text="{Binding VerdictDetail}"
                               FontSize="12.5" LineHeight="18"/>
                </StackPanel>

                <controls:ScoreDial Grid.Column="1" Width="132" Height="132" Margin="6,0"
                                    Score="{Binding CpuScore.Value}"
                                    Calibrating="{Binding CpuScore.Calibrating}"
                                    Progress="{Binding CpuScore.Progress}"
                                    Label="CPU"
                                    ToolTip="{Binding CpuScore.TopReason}"/>
                <controls:ScoreDial Grid.Column="2" Width="132" Height="132" Margin="6,0,0,0"
                                    Score="{Binding GpuScore.Value}"
                                    Calibrating="{Binding GpuScore.Calibrating}"
                                    Progress="{Binding GpuScore.Progress}"
                                    Label="GPU"
                                    ToolTip="{Binding GpuScore.TopReason}"/>
            </Grid>
        </Border>

        <!-- ================= live component cards -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Cards}" Margin="-6,8,-6,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Margin="6" Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <controls:RingGauge Grid.Column="0" Width="116" Height="116"
                                                VerticalAlignment="Center"
                                                Value="{Binding Temp}" Maximum="{Binding Limit}"
                                                HasValue="{Binding HasTemp}"
                                                SubText="{Binding LoadText}"/>

                            <Grid Grid.Column="1" Margin="16,2,0,2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <Border Background="{StaticResource Brush.AccentDim}" CornerRadius="5" Padding="7,2">
                                        <TextBlock FontFamily="{StaticResource Font.Mono}" FontSize="10.5"
                                                   FontWeight="Bold" Foreground="{StaticResource Brush.Accent}"
                                                   Text="{Binding Badge}"/>
                                    </Border>
                                    <TextBlock Margin="9,1,0,0" FontSize="11.5" Foreground="{StaticResource Brush.TextDim}"
                                               Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <ProgressBar Grid.Row="1" Style="{StaticResource LoadBar}" Margin="0,12,0,0"
                                             Minimum="0" Maximum="100" Value="{Binding Load, Mode=OneWay}"/>

                                <TextBlock Grid.Row="2" Style="{StaticResource Text.Caption}" Margin="0,8,0,0"
                                           Text="{Binding MetaText}"/>

                                <controls:Sparkline Grid.Row="3" Height="34" Margin="0,10,0,0"
                                                    VerticalAlignment="Bottom"
                                                    Values="{Binding Spark}"/>

                                <TextBlock Grid.Row="4" Margin="0,8,0,0"
                                           FontFamily="{StaticResource Font.Mono}" FontSize="11"
                                           Foreground="{StaticResource Brush.Accent}"
                                           Text="{Binding DeltaText}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ================= remarks ticker -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,10,0,0" Padding="16,11">
            <DockPanel>
                <Ellipse DockPanel.Dock="Left" Width="7" Height="7" VerticalAlignment="Center"
                         Fill="{Binding RemarkDot}"/>
                <TextBlock DockPanel.Dock="Right" Margin="12,0,0,0" VerticalAlignment="Center"
                           Style="{StaticResource Text.Caption}" Text="{Binding LatestRemarkTime}"/>
                <TextBlock Margin="11,0,0,0" VerticalAlignment="Center"
                           Style="{StaticResource Text.Body}" FontSize="12.5"
                           Text="{Binding LatestRemark}" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
