<UserControl x:Class="Kelvin.App.Views.OnboardingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Border Style="{StaticResource Card}" MaxWidth="640" VerticalAlignment="Center" Padding="36,32">
            <StackPanel>
                <TextBlock FontFamily="{StaticResource Font.Mono}" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource Brush.Text}">
                    <Run Text="K E L V I N"/><Run Text="°" Foreground="{StaticResource Brush.Accent}"/>
                </TextBlock>
                <TextBlock Style="{StaticResource Text.Dim}" FontSize="13" Margin="0,6,0,22"
                           Text="Your machine's thermal conscience."/>

                <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" LineHeight="19" Margin="0,0,0,14" TextWrapping="Wrap">
                    <Run Foreground="{StaticResource Brush.Accent}" Text="What it does — "/>
                    <Run Text="Kelvin watches CPU/GPU/SSD temperatures against the weather outside, learns what healthy looks like for this exact machine, and tells you — with evidence — when the thermal paste is due."/>
                </TextBlock>
                <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" LineHeight="19" Margin="0,0,0,14" TextWrapping="Wrap">
                    <Run Foreground="{StaticResource Brush.Accent}" Text="Privacy — "/>
                    <Run Text="your location is looked up once (or typed by you), then cached. Weather comes from Open-Meteo, keyless. Everything else stays on this machine."/>
                </TextBlock>
                <TextBlock Style="{StaticResource Text.Body}" FontSize="12.5" LineHeight="19" Margin="0,0,0,22" TextWrapping="Wrap">
                    <Run Foreground="{StaticResource Brush.Accent}" Text="The learning week — "/>
                    <Run Text="for about 7 days Kelvin quietly builds a baseline. Use the machine normally; games and heavy work teach it fastest. Hard safety limits are enforced from minute one."/>
                </TextBlock>

                <TextBlock Style="{StaticResource Text.Dim}" FontSize="12" FontFamily="{StaticResource Font.Mono}"
                           Text="{Binding MachineLine}" Margin="0,0,0,14"/>

                <Border Background="{StaticResource Brush.PanelHigh}" CornerRadius="8" Padding="12,10" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.Body}" FontSize="12" Text="{Binding LocationStatus}" TextWrapping="Wrap"/>
                        <Button Style="{StaticResource Button.Ghost}" Content="Auto-detect my city"
                                HorizontalAlignment="Left" Margin="0,8,0,0"
                                Command="{Binding DetectCommand}" IsEnabled="{Binding Busy, Converter={StaticResource InvertBool}}"/>
                    </StackPanel>
                </Border>

                <Button Style="{StaticResource Button.Primary}" HorizontalAlignment="Left" Padding="20,10"
                        FontSize="13.5" Command="{Binding StartCommand}">
                    <TextBlock Text="Start watching  →"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
